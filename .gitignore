# Python cache and build artifacts
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/
.env/
.conda/

# IDE/editor settings
.vscode/
.idea/

# OS-specific noise
.DS_Store
Thumbs.db

# Secrets and runtime config
*.env

# App-specific data directories
data/chroma_db/
data/pdfs/

# Cache directories (HuggingFace models, etc.)
cache/
.cache/
*.cache

# DVC - ignore cache and tmp, but track .dvc directory and .dvc files
.dvc/cache/
.dvc/tmp/
# Allow .dvc directory (needed for DVC to work)
!.dvc/
!.dvc/.gitignore
!.dvc/config
# Allow .dvc files (needed to track data like data/pdfs.dvc, data/chroma_db.dvc)
!*.dvc
# But ignore lock files
*.dvc.lock


/metrics.json
